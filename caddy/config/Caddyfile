(logging) {
	log {
        output file /logs/{args[0]}.log {
			roll_size 10MiB
		}
        format console {
            level_format upper
            time_format wall_milli
        }
        level DEBUG
    }
}

{
    import logging latest
}

(ovh_dns_challenge) {
    tls {
        dns ovh {
            endpoint ovh-ca
            application_key {env.OVH_APPLICATION_KEY}
            application_secret {env.OVH_APPLICATION_SECRET}
            consumer_key {env.OVH_CONSUMER_KEY}
        }
    }
}

(authentik_forward_auth) {
    route {
        reverse_proxy /outpost.goauthentik.io/* 127.0.0.1:9000

        forward_auth 127.0.0.1:9000 {
            uri /outpost.goauthentik.io/auth/caddy
            copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Entitlements X-Authentik-Email X-Authentik-Name X-Authentik-Uid X-Authentik-Jwt X-Authentik-Meta-Jwks X-Authentik-Meta-Outpost X-Authentik-Meta-Provider X-Authentik-Meta-App X-Authentik-Meta-Version
        }
    }
}

auth.{$DOMAIN_NAME} {
    import ovh_dns_challenge

    reverse_proxy 10.13.13.2:8080 {
        header_up X-Target-Service auth
    }
}

http://auth.home.arpa {
    import logging authentik_wg

    reverse_proxy 10.13.13.2:8080 {
        header_up X-Target-Service auth
    }
}

yourspotify.{$REDIRECT_DOMAIN_NAME} {
    tls internal
    redir https://yourspotify.{$DOMAIN_NAME}
}

yourspotify.{$DOMAIN_NAME} {
    import ovh_dns_challenge
    import authentik_forward_auth

    reverse_proxy 10.13.13.2:8080 {
        header_up X-Target-Service spotify
    }

    import logging spotify
}

