{
    log {
        output file /logs/latest.log {
            roll_size 10MiB
        }
        format console
        level INFO
    }
}

(ovh_dns_challenge) {
    tls {
        dns ovh {
            endpoint ovh-ca
            application_key {env.OVH_APPLICATION_KEY}
            application_secret {env.OVH_APPLICATION_SECRET}
            consumer_key {env.OVH_CONSUMER_KEY}
        }
    }
}

yourspotify.{$REDIRECT_DOMAIN_NAME} {
    tls internal
    redir https://yourspotify.{$DOMAIN_NAME}
}

