yourspotify.{$DOMAIN_NAME} {
    import ovh_dns_challenge

    reverse_proxy 10.13.13.2:8080 {
        header_up X-Target-Service spotify
    }

    log {
        output file /logs/spotify.log {
			roll_size 10MiB
		}
        format console
        level DEBUG
    }
}
